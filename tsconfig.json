{
	"extends": "astro/tsconfigs/strict",
	"include": [
		".astro/types.d.ts",
		"**/*",
		".storybook/declarations.d.ts",
	],
	"exclude": [
		"dist"
	],
	"compilerOptions": {
		"strictNullChecks": true,
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"src/*"
			]
		},
		"jsx": "react-jsx",
		"jsxImportSource": "react"
	}
}