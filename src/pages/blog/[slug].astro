---
import {
	getCollection,
	type CollectionEntry,
	render,
} from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PostTags from "@/components/PostTags.astro";
import PostCoverImage from "@/components/PostCoverImage.astro";
import PostInfo from "@/components/PostInfo.astro";
import Comments from "@/components/Comments.astro";
import type { MarkdownHeading } from "astro";
import TableOfContents from "@/components/TableOfContents.astro";
import ReadingIndicator from "@/components/ReadingIndicator.astro";
import { slide } from "astro:transitions";

export const getStaticPaths = async () => {
	const blogs = await getCollection("blogs");

	const headings = await Promise.all(
		blogs.map((entry) =>
			render(entry).then(({ headings }) => headings),
		),
	);

	return blogs.map((blog, index) => {
		return {
			params: {
				slug: blog.id,
			},
			props: { blog, headings: headings[index] },
		};
	});
};

type Props = {
	blog: CollectionEntry<"blogs">;
	headings: MarkdownHeading[];
};

const { blog, headings } = Astro.props;
const { Content } = await render(blog);

const { title, excerpt, coverImage, publishedDate, tags, author, avatar } =
	blog.data;

const wordCount = blog.body?.split(/\s+/).length || 0;

const coverImageURL =
	typeof coverImage === "string" ? coverImage : coverImage?.src;
---

<Layout title={title} description={excerpt} image={coverImageURL}>
	<ReadingIndicator slot="reading-indicator" />
	<main
		id="main-content"
		class="mx-auto"
		transition:animate={slide({ duration: "0.3s" })}
	>
		<article>
			<PostCoverImage coverImage={coverImage} />
			<div class="mx-auto my-3 w-[95%] md:max-w-xl lg:max-w-3xl">
				<h1
					class="bg-linear-to-br from-black via-neutral-700 to-neutral-400 bg-clip-text text-center text-xl font-semibold text-transparent sm:text-3xl lg:text-4xl dark:bg-linear-to-br dark:from-neutral-100 dark:via-neutral-300 dark:to-neutral-600"
				>
					{title}
				</h1>
				<PostInfo
					avatar={avatar}
					author={author}
					publishedDate={publishedDate}
					wordCount={wordCount}
				/>
				<PostTags tags={tags} />
			</div>
			<div
				class="relative mx-auto my-10 grid max-w-7xl grid-cols-1 gap-2 xl:grid-cols-[1fr_minmax(auto,auto)_1fr]"
			>
				<TableOfContents headings={headings} />
				<div class="md:min-w-3xl">
					<div
						class="prose text-muted prose-headings:text-foreground prose-a:text-blue-400 prose-img:rounded-lg prose-h1:text-2xl prose-h2:text-xl prose-h3:text-lg prose-h4:text-base prose-h5:text-sm relative mx-auto mb-20 w-[95%] overflow-visible px-2 sm:px-0 md:max-w-xl lg:max-w-3xl"
					>
						<Content />
					</div>
					<Comments />
				</div>
			</div>
		</article>
	</main>
</Layout>
