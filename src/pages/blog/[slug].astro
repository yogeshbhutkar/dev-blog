---
import {
	getCollection,
	type CollectionEntry,
	render,
} from "astro:content";
import type { MarkdownHeading } from "astro";
import Layout from "@/layouts/Layout.astro";
import PostTags from "@/components/PostTags.astro";
import PostCoverImage from "@/components/PostCoverImage.astro";
import PostInfo from "@/components/PostInfo.astro";
import Comments from "@/components/Comments.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import ReadingIndicator from "@/components/ReadingIndicator.astro";
import ScrollToTop from "@/components/ScrollToTop.astro";
import SinglePostPagination from "@/components/SinglePostPagination.astro";

export const getStaticPaths = async () => {
	const blogs = (await getCollection("blogs")).sort(
		(a, b) =>
			new Date(b.data.publishedDate).getTime() -
			new Date(a.data.publishedDate).getTime(),
	);

	const headings = await Promise.all(
		blogs.map((entry) =>
			render(entry).then(({ headings }) => headings),
		),
	);

	return blogs.map((blog, index) => {
		return {
			params: {
				slug: blog.id,
			},
			props: {
				blog,
				headings: headings[index],
				next: blogs[index - 1] ?? null,
				prev: blogs[index + 1] ?? null,
			},
		};
	});
};

type Props = {
	blog: CollectionEntry<"blogs">;
	headings: MarkdownHeading[];
	next: CollectionEntry<"blogs"> | null;
	prev: CollectionEntry<"blogs"> | null;
};

const { blog, headings, next, prev } = Astro.props;
const { Content } = await render(blog);

const { title, excerpt, coverImage, publishedDate, tags, author, avatar } =
	blog.data;

const wordCount = blog.body?.split(/\s+/).length || 0;

const coverImageURL =
	typeof coverImage === "string" ? coverImage : coverImage?.src;
---

<Layout title={title} description={excerpt} image={coverImageURL}>
	<ReadingIndicator slot="reading-indicator" />
	<main id="main-content" class="mx-auto">
		<article>
			<PostCoverImage coverImage={coverImage} />
			<div class="mx-auto my-3 w-[95%] md:max-w-xl lg:max-w-3xl">
				<h1
					class="bg-linear-to-br from-black via-neutral-700 to-neutral-400 bg-clip-text text-center text-xl font-medium text-transparent sm:text-3xl lg:text-4xl dark:bg-linear-to-br dark:from-neutral-100 dark:via-neutral-300 dark:to-neutral-600"
				>
					{title}
				</h1>
				<PostInfo
					avatar={avatar}
					author={author}
					publishedDate={publishedDate}
					wordCount={wordCount}
				/>
				<PostTags tags={tags} />
			</div>
			<div
				class="relative mx-auto my-10 grid max-w-7xl grid-cols-1 gap-2 xl:grid-cols-[1fr_minmax(auto,auto)_1fr]"
			>
				<TableOfContents headings={headings} />
				<div class="md:min-w-3xl">
					<div
						class="prose text-muted prose-headings:text-foreground prose-a:text-foreground prose-a:font-normal prose-img:rounded-lg prose-h1:text-2xl prose-h2:text-xl prose-h3:text-lg prose-h4:text-base prose-h5:text-sm prose-headings:font-medium prose-strong:text-foreground prose-figcaption:text-muted prose-p:mb-7 relative mx-auto my-5 overflow-visible px-4 font-light sm:px-0 md:max-w-xl lg:max-w-3xl [&_:is(h3,h4,h5,h6)]:mt-10"
					>
						<Content />
					</div>

					<div
						role="separator"
						class="text-muted/40 flex items-center justify-center py-5 select-none"
					>
						<span
							aria-hidden="true"
							class="font-serif text-lg tracking-[0.75em]"
							>* * *</span
						>
					</div>

					<SinglePostPagination
						next={next}
						prev={prev}
						classname="my-14"
					/>

					<Comments />
				</div>
			</div>
		</article>
	</main>

	<ScrollToTop />
</Layout>
