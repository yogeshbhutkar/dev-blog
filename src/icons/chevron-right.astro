---
interface Props {
	class?: string;
	width?: number;
	height?: number;
}

const { class: className = "", width = 24, height = 24 } = Astro.props;
---

<svg
	xmlns="http://www.w3.org/2000/svg"
	width={width}
	height={height}
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width="2"
	stroke-linecap="round"
	stroke-linejoin="round"
	class={className}
>
	<title>Right Arrow</title>
	<path d="m9 18 6-6-6-6"></path>
</svg>
