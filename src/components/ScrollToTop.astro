---
import ChevronTop from "@/icons/chevron-top.astro";
---

<button
	id="scroll-to-top"
	class="text-background invisible fixed right-4 bottom-4 cursor-pointer rounded-full bg-neutral-700 p-3 opacity-0 shadow-lg transition-all duration-300 hover:bg-neutral-800 hover:shadow-xl active:scale-95 sm:right-8 sm:bottom-8 dark:bg-gray-100 hover:dark:bg-white"
	title="Scroll to top"
>
	<ChevronTop class="h-5 w-5" />
</button>

<script>
	const SCROLL_THRESHOLD = 300;

	const setupScrollToTopButton = () => {
		const scrollToTopBtn = document.getElementById("scroll-to-top");
		if (!scrollToTopBtn) {
			return;
		}

		// Show/hide button based on scroll position
		window.addEventListener(
			"scroll",
			() => {
				const shouldShow = window.scrollY > SCROLL_THRESHOLD;

				scrollToTopBtn.classList.toggle("opacity-0", !shouldShow);
				scrollToTopBtn.classList.toggle("invisible", !shouldShow);
				scrollToTopBtn.classList.toggle("opacity-100", shouldShow);
				scrollToTopBtn.classList.toggle("visible", shouldShow);
			},
			// Only listen to scroll event without stopping/interfering with it.
			{ passive: true },
		);

		// Scroll to top on click
		scrollToTopBtn.addEventListener("click", () => {
			window.scrollTo({
				top: 0,
				behavior: "smooth",
			});
		});
	};

	setupScrollToTopButton();
	document.addEventListener("astro:page-load", setupScrollToTopButton);
</script>
